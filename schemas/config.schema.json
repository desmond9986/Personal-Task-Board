{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "config.schema.json",
  "title": "Personal Task Board Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "ownerName", "options", "sync", "sensitiveDataPolicy", "views"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "ownerName": { "type": "string", "minLength": 1 },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statuses", "types", "priorities", "energies", "evidenceStates"],
      "properties": {
        "statuses": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "types": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "priorities": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "energies": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "evidenceStates": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "sync": {
      "type": "object",
      "additionalProperties": false,
      "required": ["externalTicketSyncEnabled", "ticketSystemProvider", "mcpPreferred", "browserFallback", "frequency"],
      "properties": {
        "externalTicketSyncEnabled": { "type": "boolean" },
        "ticketSystemProvider": { "type": "string" },
        "mcpPreferred": { "type": "boolean" },
        "browserFallback": { "type": "boolean" },
        "frequency": { "type": "string", "enum": ["manual", "startup_check", "daily", "weekly", "disabled"] }
      }
    },
    "sensitiveDataPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultMode", "localPrivateDetailsAllowed", "warning"],
      "properties": {
        "defaultMode": { "type": "string", "enum": ["sanitized_by_default"] },
        "localPrivateDetailsAllowed": { "type": "boolean" },
        "warning": { "type": "string", "minLength": 1 }
      }
    },
    "views": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "filter"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "filter": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "status": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              },
              "excludeStatus": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              },
              "type": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              },
              "priority": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              },
              "evidenceState": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              },
              "agentHelpWanted": { "type": "boolean" },
              "targetSoonDays": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
